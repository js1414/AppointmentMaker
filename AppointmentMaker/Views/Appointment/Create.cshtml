@model AppointmentMaker.Models.AppointmentModel

<div class="container mt-4">
    <div class="card  shadow-lg border-0 rounded-3">
        <div class="card-header bg-dark text-white fw-bold">
            Appointment Details
        </div>

        <div class="card-body">
            <form asp-action="Details">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-semibold"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Date" class="form-label fw-semibold"></label>
                    <input asp-for="Date" type="date" class="form-control" />
                    <span asp-validation-for="Date" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="DoctorRoom" class="form-label fw-semibold"></label>
                    <input asp-for="DoctorRoom" class="form-control" />
                    <span asp-validation-for="DoctorRoom" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="DoctorName" class="form-label fw-semibold"></label>
                    <input asp-for="DoctorName" class="form-control" />
                    <span asp-validation-for="DoctorName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="PainLevel" class="form-label fw-semibold"></label>
                    <input asp-for="PainLevel" type="number" min="1" max="10" class="form-control" />
                    <span asp-validation-for="PainLevel" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center">
                    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
                    <input type="submit" value="Create" class="btn btn-success px-4" />
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}