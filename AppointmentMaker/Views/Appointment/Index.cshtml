@model IEnumerable<AppointmentMaker.Models.AppointmentModel>

<div class="mb-3">
    <a asp-action="Create" class="btn btn-primary btn-sm bg-success">Create New Appointment</a>
</div>

<table class="table table-sm table-bordered table-hover align-middle text-center small fw-light">
    <thead class="table-dark small fw-light">
        <tr>
            <th>@Html.DisplayNameFor(model => model.Name)</th>
            <th>@Html.DisplayNameFor(model => model.Date)</th>
            <th>@Html.DisplayNameFor(model => model.DoctorRoom)</th>
            <th>@Html.DisplayNameFor(model => model.DoctorName)</th>
            <th>@Html.DisplayNameFor(model => model.PainLevel)</th>
            <th style="width: 200px;">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Date.ToString("dd MMM yyyy - HH:mm")</td>
                <td>@item.DoctorRoom</td>
                <td>@item.DoctorName</td>
                <td>@item.PainLevel</td>

                <!-- Centered horizontal text-only buttons -->
                <td>
                    <div class="d-flex justify-content-center gap-1">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="ext-decoration-none text-primary text-center small fw-light">Edit</a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="text-success text-center small fw-light">Details</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="text-danger text-center small fw-light">Delete</a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>