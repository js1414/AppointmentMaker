@model AppointmentMaker.Models.RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 100vh;">
    <div class="card shadow-lg border-0 rounded-4 p-4" style="max-width: 420px; width: 100%;">
        <div class="card-body">
            <h3 class="text-center mb-4 text-primary fw-bold">Create Account</h3>

            <div asp-validation-summary="All" class="text-danger"></div>
            <form asp-action="Register" method="post">
                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-semibold"></label>
                    <input asp-for="Email" class="form-control rounded-pill" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-semibold"></label>
                    <input asp-for="Password" class="form-control rounded-pill" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label fw-semibold"></label>
                    <input asp-for="FullName" class="form-control rounded-pill" />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="DateOfBirth" class="form-label fw-semibold"></label>
                    <input asp-for="DateOfBirth" class="form-control rounded-pill" />
                    <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-primary rounded-pill fw-semibold py-2">Register</button>
                </div>
            </form>

            <div class="text-center mt-4">
                <p class="small text-muted">
                    Already have an account?
                    <a asp-action="Login" class="text-decoration-none text-primary fw-semibold">Sign In</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}